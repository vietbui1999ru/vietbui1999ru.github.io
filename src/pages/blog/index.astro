---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { toSlug } from "@/lib/utils";
import { Calendar, FileText } from "lucide-react";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}
---

<BaseLayout>
  <div class="w-full flex-1 bg-background">
    <div class="mx-auto w-full max-w-[var(--content-max)] px-4 py-24 sm:px-6">
      <h1 class="text-4xl font-bold mb-8">Blog</h1>

      <!-- Horizontal scroll strip — 1 row, snaps per card -->
      <div class="flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {posts.map((post) => {
          const slug = toSlug(post.id);
          return (
            <a
              href={`/blog/${slug}`}
              class="group snap-start flex-shrink-0 w-72 sm:w-80 flex flex-col rounded-xl border border-border bg-card text-card-foreground shadow-sm hover:shadow-md hover:border-primary/40 transition-all duration-200 overflow-hidden"
            >
              <!-- Placeholder cover -->
              <div class="aspect-video w-full flex items-center justify-center bg-muted/50">
                <FileText className="size-10 text-muted-foreground/40 group-hover:text-muted-foreground/60 transition-colors" />
              </div>

              <div class="flex flex-col flex-1 p-5 gap-3">
                <h2 class="font-semibold text-base leading-snug line-clamp-2 group-hover:text-primary transition-colors">
                  {post.data.title}
                </h2>

                <p class="text-sm text-muted-foreground line-clamp-2 flex-1">
                  {post.data.description}
                </p>

                <div class="flex flex-wrap items-center justify-between gap-2 mt-auto pt-1">
                  <span class="flex items-center gap-1 text-xs text-muted-foreground">
                    <Calendar className="size-3" />
                    {formatDate(post.data.date)}
                  </span>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2 py-0.5 rounded-full text-xs bg-secondary text-secondary-foreground">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</BaseLayout>
